# ====================== BINANCE API (REQUIRED) ======================
# Get from https://www.binance.com/en/demo-fapi (Demo Futures)
BINANCE_TEST_API="your_api_key_here"
BINANCE_TEST_SECRET="your_secret_key_here"

# Set to true ONLY when ready for real money (USE WITH EXTREME CAUTION)
USE_LIVE=false

# ====================== DATABASE (REQUIRED) ======================
# Supabase free tier: https://supabase.com
SUPABASE_DB_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# ====================== EMAIL ALERTS (OPTIONAL) ======================
# Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
EMAIL_FROM=""
EMAIL_TO=""
EMAIL_APP_PASSWORD=""
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=465

# ====================== TRADE CONTROLS ======================
MAX_OPEN_POSITIONS=3
MAX_DAILY_TRADES=6
TRADE_COOLDOWN_MINUTES=45
LEVERAGE=10

# ====================== RISK MANAGEMENT ======================
RISK_PER_TRADE_PCT=0.5        # Risk 0.5% of equity per trade
DAILY_LOSS_LIMIT_PCT=2.0      # Pause if daily loss exceeds -2%
MAX_DRAWDOWN_PCT=8.0           # Kill-switch at -8% from peak
MAX_CORRELATED_EXPOSURE_PCT=30.0

# ====================== STRATEGY ======================
MIN_CONFIDENCE=70
ML_MIN_PROBABILITY=0.65
ADX_MIN_THRESHOLD=25.0
VOLUME_CONFIRMATION_RATIO=0.8
ENABLE_TRAILING_STOP=YES
ENABLE_ML_LAYER=YES

# ====================== ML ======================
ML_RETRAIN_HOUR=2             # Retrain at 2 AM UTC
ML_LOOKBACK_DAYS=180
ML_WALK_FORWARD_TRAIN=90
ML_WALK_FORWARD_TEST=30

# ====================== MONITORING ======================
HEALTH_CHECK_PORT=8080
DASHBOARD_PORT=5000
PERFORMANCE_DEVIATION_THRESHOLD=15.0

# ====================== HIGH IMPACT NEWS DATES ======================
# Comma-separated YYYY-MM-DD dates to skip trading
HIGH_IMPACT_DATES=""

# ====================== PATHS ======================
LOG_FILE=signals_log.csv
ML_MODEL_DIR=ml_models
HISTORICAL_DATA_DIR=historical_data
TRADE_JOURNAL_FILE=trade_journal.csv
